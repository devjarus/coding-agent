{
  "hooks": {
    "SubagentStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "AGENT_NAME=$(cat /dev/stdin | jq -r '.agent_type // \"unknown\"') && echo \"[$(date '+%H:%M:%S')] Agent dispatched: $AGENT_NAME\" >> .coding-agent/agent-log.txt"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/post-edit-validate.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
